{
  "name": "Protect release tags",
  "target": "tag",
  "source_type": "Repository",
  "source": "RichardGeorgeDavis/Codex-Workspace",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/tags/v*"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    }
  ],
  "bypass_actors": []
}
